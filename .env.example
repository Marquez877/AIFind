# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=archive_db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/archive_db

# API Keys (получите у организаторов)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# JWT
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32

# App
APP_ENV=development

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173,https://aifindd.vercel.app,https://universalaifind.xyz
CORS_ALLOW_ORIGIN_REGEX=^https://.*\.vercel\.app$
